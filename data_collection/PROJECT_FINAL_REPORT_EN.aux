\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Learning curves showing training and validation performance over epochs for selected models. The curves demonstrate convergence behavior and help identify optimal stopping points to prevent overfitting.}}{6}{figure.4}\protected@file@percent }
\newlabel{fig:learning_curves}{{4}{6}{Learning curves showing training and validation performance over epochs for selected models. The curves demonstrate convergence behavior and help identify optimal stopping points to prevent overfitting}{figure.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Model performance comparison on the 322-sample experimental dataset. Performance metrics include coefficient of determination ($R^2$), root mean squared error (RMSE), and mean absolute error (MAE).}}{6}{table.1}\protected@file@percent }
\newlabel{tab:model_performance}{{1}{6}{Model performance comparison on the 322-sample experimental dataset. Performance metrics include coefficient of determination ($R^2$), root mean squared error (RMSE), and mean absolute error (MAE)}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Comparison of model performance metrics (R$^2$ and RMSE) across different machine-learning algorithms. The optimized SVR and Gradient Boosting models show the best performance, with R$^2$ values of approximately 0.59 and 0.67, respectively.}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:model_performance}{{5}{7}{Comparison of model performance metrics (R$^2$ and RMSE) across different machine-learning algorithms. The optimized SVR and Gradient Boosting models show the best performance, with R$^2$ values of approximately 0.59 and 0.67, respectively}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Comprehensive comparison of all models showing performance across different metrics and data subsets. This visualization helps identify the best-performing models for different use cases.}}{8}{figure.6}\protected@file@percent }
\newlabel{fig:model_comparison_all}{{6}{8}{Comprehensive comparison of all models showing performance across different metrics and data subsets. This visualization helps identify the best-performing models for different use cases}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Detailed comparison of performance metrics (R$^2$, RMSE, MAE) for all evaluated models, highlighting the trade-offs between different evaluation criteria.}}{8}{figure.7}\protected@file@percent }
\newlabel{fig:performance_metrics}{{7}{8}{Detailed comparison of performance metrics (R$^2$, RMSE, MAE) for all evaluated models, highlighting the trade-offs between different evaluation criteria}{figure.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Feature importance analysis from Random Forest regression. The Ti composition fraction (\texttt  {comp\_Ti}) shows the highest importance (approximately 16--17\%), followed by average electronegativity, valence electron concentration (VEC), Co composition fraction, and density.}}{9}{figure.8}\protected@file@percent }
\newlabel{fig:feature_importance}{{8}{9}{Feature importance analysis from Random Forest regression. The Ti composition fraction (\texttt {comp\_Ti}) shows the highest importance (approximately 16--17\%), followed by average electronegativity, valence electron concentration (VEC), Co composition fraction, and density}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Predicted vs.\ actual elastic modulus values for the optimized SVR model on the 322-sample dataset. The diagonal line represents perfect prediction. Most predictions cluster around the diagonal, indicating reasonable model calibration, though some scatter is present, particularly at the extremes of the modulus range.}}{9}{figure.9}\protected@file@percent }
\newlabel{fig:predicted_vs_actual}{{9}{9}{Predicted vs.\ actual elastic modulus values for the optimized SVR model on the 322-sample dataset. The diagonal line represents perfect prediction. Most predictions cluster around the diagonal, indicating reasonable model calibration, though some scatter is present, particularly at the extremes of the modulus range}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Predicted vs.\ actual elastic modulus for models evaluated on the experimental-only subset. This comparison helps assess model performance when applied to purely experimental data, avoiding potential biases from computed values.}}{10}{figure.10}\protected@file@percent }
\newlabel{fig:predicted_vs_actual_measured}{{10}{10}{Predicted vs.\ actual elastic modulus for models evaluated on the experimental-only subset. This comparison helps assess model performance when applied to purely experimental data, avoiding potential biases from computed values}{figure.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Residual analysis for the optimized SVR model. The residuals are approximately centered around zero with no strong systematic trends, suggesting that the model captures the main relationships without severe bias. Larger errors tend to occur at the extremes of the modulus distribution.}}{10}{figure.11}\protected@file@percent }
\newlabel{fig:residuals}{{11}{10}{Residual analysis for the optimized SVR model. The residuals are approximately centered around zero with no strong systematic trends, suggesting that the model captures the main relationships without severe bias. Larger errors tend to occur at the extremes of the modulus distribution}{figure.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Distribution of prediction errors across all models. The error distributions help identify systematic biases and assess the reliability of predictions for different modulus ranges.}}{11}{figure.12}\protected@file@percent }
\newlabel{fig:error_distribution}{{12}{11}{Distribution of prediction errors across all models. The error distributions help identify systematic biases and assess the reliability of predictions for different modulus ranges}{figure.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Performance improvement achieved through hyperparameter optimization. The comparison shows the gains from systematic tuning of model parameters, particularly for SVR and Gradient Boosting models.}}{11}{figure.13}\protected@file@percent }
\newlabel{fig:performance_improvement}{{13}{11}{Performance improvement achieved through hyperparameter optimization. The comparison shows the gains from systematic tuning of model parameters, particularly for SVR and Gradient Boosting models}{figure.13}{}}

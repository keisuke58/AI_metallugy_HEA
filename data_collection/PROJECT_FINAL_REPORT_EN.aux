\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Comparison of elastic modulus ranges for human bone, conventional metallic biomaterials, and target range for biomedical HEA/MPEA alloys. The mismatch between bone (10--30\nobreakspace  {}GPa) and traditional implants (100--200\nobreakspace  {}GPa) motivates the design of low-modulus alloys in the 30--90\nobreakspace  {}GPa range.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:elastic_modulus_comparison}{{1}{2}{Comparison of elastic modulus ranges for human bone, conventional metallic biomaterials, and target range for biomedical HEA/MPEA alloys. The mismatch between bone (10--30~GPa) and traditional implants (100--200~GPa) motivates the design of low-modulus alloys in the 30--90~GPa range}{figure.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {2}Data and Dataset Construction}{2}{section.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}Data Sources}{2}{subsection.2.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Integration and Cleaning}{3}{subsection.2.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}Dataset Characteristics}{3}{subsection.2.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Distribution of elastic modulus values in the integrated dataset (5{,}339 samples). The histogram shows a broad distribution spanning from approximately 2.7\nobreakspace  {}GPa to 621\nobreakspace  {}GPa, with a mean around 139\nobreakspace  {}GPa. The target range for biomedical applications (30--90\nobreakspace  {}GPa) is highlighted.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:data_distribution}{{2}{4}{Distribution of elastic modulus values in the integrated dataset (5{,}339 samples). The histogram shows a broad distribution spanning from approximately 2.7~GPa to 621~GPa, with a mean around 139~GPa. The target range for biomedical applications (30--90~GPa) is highlighted}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Key characteristics of the integrated dataset, including source breakdown, experimental vs.\ computed data distribution, and statistical properties of the elastic modulus values.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:data_characteristics}{{3}{4}{Key characteristics of the integrated dataset, including source breakdown, experimental vs.\ computed data distribution, and statistical properties of the elastic modulus values}{figure.3}{}}
